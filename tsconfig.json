{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "rootDir": "./src",

  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
